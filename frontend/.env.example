# Copie para .env: na pasta frontend execute
#   copy .env.example .env   (Windows)
# Reinicie o Vite após alterar (Ctrl+C e npm run dev).

# --- API na nuvem ---
# Descomente e coloque o host da API (sem /api no fim). CORS no servidor deve incluir http://localhost:5173
# VITE_URL_BASE_API=http://SEU_IP_OU_DOMINIO

# --- API local (proxy) ---
# Usado quando VITE_URL_BASE_API está vazio/ausente: o browser pede /api/... ao Vite e o Vite encaminha para o backend.
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:5000
