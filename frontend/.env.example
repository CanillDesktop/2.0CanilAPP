# Copie para .env: na pasta frontend execute
#   copy .env.example .env   (Windows)
# Reinicie o Vite após alterar (Ctrl+C e npm run dev).

# --- URL absoluta da API (opcional) ---
# Para `npm run dev` com proxy em :5173, NÃO defina VITE_URL_BASE_API (deixe comentado).
# Se apontar para http://127.0.0.1:5000 ou :5000, o browser faz CORS e pode falhar com "Network Error"
# (sobretudo se o backend estiver em Production sem Cors:AllowedOrigins).
# VITE_URL_BASE_API=https://sua-api-publica.com

# --- API local (proxy) ---
# Frontend (Vite): http://127.0.0.1:5173/ (preferir a IPv4; "localhost" pode falhar no Windows com Firefox).
# Chamadas /api/... vão para o backend abaixo (sem CORS no browser).
# Usado quando VITE_URL_BASE_API está vazio/ausente.
#VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:5000
