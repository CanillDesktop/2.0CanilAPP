{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: vite dev (proxy API)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "VITE_DEV_API_PROXY_TARGET": "http://127.0.0.1:5000"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": ".", "file": 1, "location": 1, "message": 1 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+https?://"
        }
      }
    }
  ]
}

